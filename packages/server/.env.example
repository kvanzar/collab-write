# --- Database (required) ---
DATABASE_URL=postgres://localhost:5432/collabwrite

# --- Redis (optional: enables multi-node sync; omit for single-node) ---
REDIS_URL=redis://localhost:6379

# --- HTTP ---
PORT=3001

# --- Sessions (REQUIRED in production; any long random string) ---
SESSION_SECRET=

# --- Google OAuth (optional in dev — dev login is used when unset) ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials
#   → Create OAuth client ID → Web application
#   → Authorized redirect URI must EXACTLY match GOOGLE_CALLBACK_URL below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev (through the Vite proxy):
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
# Production: https://your-domain.com/api/auth/google/callback
